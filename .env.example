# Entra ID App Registration (client credentials flow)
# The service principal must have the System Administrator or equivalent role in the target Dataverse environment.
# It is ALSO used for UpdateApprovalStatus — Microsoft requires the approval action to run as the SP.
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-app-registration-client-secret
AZURE_TENANT_ID=your-entra-tenant-id

# Dataverse / Power Platform environment URL (e.g. https://yourorg.crm.dynamics.com)
DATAVERSE_URL=https://yourorg.crm.dynamics.com

# Port the HTTP server listens on (defaults to 3000)
PORT=3000
